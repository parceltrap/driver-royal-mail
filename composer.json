{
    "name": "parceltrap/driver-royal-mail",
    "type": "library",
    "description": "A Royal Mail driver for ParcelTrap",
    "license": "MIT",
    "keywords": [
        "parceltrap-driver"
    ],
    "require": {
        "php": "^8.4",
        "graham-campbell/guzzle-factory": "^7.0",
        "parceltrap/parceltrap": "^1.5"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1.45",
        "symfony/var-dumper": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "ParcelTrap\\RoyalMail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ParcelTrap\\RoyalMail\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:types": "phpstan analyse --ansi --memory-limit=-1",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ParcelTrap\\RoyalMail\\RoyalMailServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
